# Environment variables for {{ cookiecutter.project_name }}
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── LLM provider ─────────────────────────────────────────────────────────────
# Add the API key for your chosen LLM provider.
# Examples: ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_CLOUD_PROJECT
LLM_API_KEY=
LLM_MODEL=

# ── Vector store ──────────────────────────────────────────────────────────────
VECTOR_STORE_URL=

# ── Memory store ──────────────────────────────────────────────────────────────
MEMORY_STORE_URL=

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Monitoring / tracing ──────────────────────────────────────────────────────
TRACING_ENABLED=false
TRACING_API_KEY=

# ── Add your project-specific variables below ─────────────────────────────────
